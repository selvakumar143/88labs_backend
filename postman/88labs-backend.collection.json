      ]
    },
    {
      "name": "2. Admin",
      "item": [
        {
          "name": "Create Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('client created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "const client = json.data || {};",
                  "if (client.id) {",
                  "  pm.environment.set('created_client_id', client.id);",
                  "}",
                  "if (client.primary_admin_user_id) {",
                  "  pm.environment.set('created_client_primary_admin_user_id', client.primary_admin_user_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientCode\": \"CL-POSTMAN-001\",\n  \"clientName\": \"Postman Client\",\n  \"email\": \"postman.client@example.com\",\n  \"country\": \"India\",\n  \"phone\": \"9999999998\",\n  \"clientType\": \"Agency\",\n  \"niche\": \"Ecommerce\",\n  \"marketCountry\": \"India\",\n  \"settlementMode\": \"Bank Transfer\",\n  \"statementCycle\": \"Monthly\",\n  \"settlementCurrency\": \"INR\",\n  \"cooperationStart\": \"2026-03-13\",\n  \"serviceFeePercent\": 5,\n  \"serviceFeeEffectiveTime\": \"2026-03-13 10:00:00\"\n}"
            },
            "url": "{{base_url}}/admin/clients"
          }
        },
