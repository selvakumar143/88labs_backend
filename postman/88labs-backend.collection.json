              "raw": "{\n  \"name\": \"Postman Sub User\",\n  \"email\": \"{{sub_user_email}}\",\n  \"password\": \"{{sub_user_password}}\",\n  \"password_confirmation\": \"{{sub_user_password}}\",\n  \"role\": \"client_manager\",\n  \"status\": \"active\",\n  \"send_invite\": false\n}"
            },
            "url": "{{base_url}}/client/team-users"
