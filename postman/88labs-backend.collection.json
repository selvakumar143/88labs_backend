          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sub_user_email}}\",\n  \"password\": \"{{sub_user_password}}\"\n}"
            },
            "url": "{{base_url}}/customer/login"
          }
