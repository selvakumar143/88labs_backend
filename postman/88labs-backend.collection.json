{
  "info": {
    "_postman_id": "77f5d1d9-5e4b-4a79-9d3a-88labs-backend-collection",
    "name": "88Labs Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth, admin, client, and sub-user test flow for the 88Labs backend. Note: POST /admin/clients creates a passwordless invited client, so login flow uses the seeded client@example.com account unless you complete the password setup flow from email."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('sub_user_email')) {",
          "  pm.environment.set('sub_user_email', `subuser+${Date.now()}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('admin_token', json.token);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "  pm.environment.set('admin_user_id', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/admin/login"
          }
        },
        {
          "name": "Client Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('client login ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('client_token', json.token);",
                  "}",
                  "if (json.user && json.user.id) {",
                  "  pm.environment.set('client_user_id', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{client_email}}\",\n  \"password\": \"{{client_password}}\"\n}"
            },
            "url": "{{base_url}}/customer/login"
          }
        },
        {
          "name": "Sub User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('sub user login ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
